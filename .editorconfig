root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.sh]
indent_style = space
indent_size = 2
# shfmt-specific settings
switch_case_indent = true

[{.github/*-wrapper,.*-wrapper.sh}]
indent_style = space
indent_size = 2
switch_case_indent = true
